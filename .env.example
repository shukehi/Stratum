# Stratum v0.13 - 物理动能引擎配置模板 (V3 Physics)

# --- [运行模式 (TASK-P3-C)] ---
#   paper - 纸上模拟交易模式（默认），数据落库，信号推送
#   live  - 实盘交易模式（慎用！），先调用交易所 API 开仓，成功后落库
EXECUTION_MODE=paper

# --- [API 密钥 (实盘必填)] ---
# 仅在 EXECUTION_MODE=live 时生效
EXCHANGE_API_KEY=
EXCHANGE_SECRET=

# --- [物理核心] ---
EXCHANGE_NAME=binanceusdm
# 合约交易对格式 (CCXT 标准)
SYMBOL=BTC/USDT:USDT
# 现货对照品种
SPOT_SYMBOL=BTC/USDT

# --- [存储] ---
DATABASE_URL=./stratum.db

# --- [风险参数 (物理推力)] ---
# 初始账户规模 (USD)
ACCOUNT_SIZE=10000
# 每笔交易固定风险比例 (0.01 = 1%)
RISK_PER_TRADE=0.01

# --- [故障遥测与通知 (FSD Silent Mode)] ---
# 在 FSD 模式下，系统仅在发生 API 崩溃或信号触发时发送推送
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_COMMAND_BOT_ENABLED=false
# DISCORD_WEBHOOK_URL=
# DISCORD_BOT_ENABLED=false

# --- [运行环境] ---
# 建议设为 info 保持静默，debug 可查看 3-Sigma 动能细节
LOG_LEVEL=info
NODE_ENV=production
HEARTBEAT_INTERVAL_H=6
