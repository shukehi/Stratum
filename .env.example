# Stratum 2.0 - 物理动能引擎配置模板 (V2 Physics)

# --- [物理核心] ---
EXCHANGE_NAME=binanceusdm
# 合约交易对格式 (CCXT 标准)
SYMBOL=BTC/USDT:USDT
# 现货对照品种
SPOT_SYMBOL=BTC/USDT

# --- [存储] ---
DATABASE_URL=./stratum.db

# --- [风险参数 (物理推力)] ---
# 初始模拟账户规模 (USD)
ACCOUNT_SIZE=10000
# 每笔交易固定风险比例 (0.01 = 1%)
RISK_PER_TRADE=0.01

# --- [故障遥测 (FSD Silent Mode)] ---
# 在 FSD 模式下，系统仅在发生 API 崩溃或严重滑点时发送紧急推送
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# DISCORD_WEBHOOK_URL=

# --- [运行环境] ---
# 建议设为 info 保持静默，debug 可查看 3-Sigma 动能细节
LOG_LEVEL=info
NODE_ENV=production
