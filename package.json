{
  "name": "stratum",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --env-file=.env src/index.ts",
    "report": "tsx --env-file=.env src/cli/index.ts report",
    "positions": "tsx --env-file=.env src/cli/index.ts positions",
    "backtest": "tsx --env-file=.env src/cli/index.ts backtest",
    "cli": "tsx --env-file=.env src/cli/index.ts",
    "deploy:vps": "bash ./scripts/deploy-vps.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "ccxt": "^4.3.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
